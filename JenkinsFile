pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Rajkumarhubv/PJPractice.git'
            }
        }

        stage('Install') {
            steps {
                bat 'npm install'
                bat 'npx playwright install'
            }
        }

        stage('Run Tests') {
            steps {
                // Force HTML report generation
                bat 'npx playwright test --reporter=html'
            }
        }

        stage('Verify Report') {
            steps {
                // Debug: check if report files exist
                bat 'dir playwright-report'
            }
        }
    }

    post {
        always {
            // Archive report
            archiveArtifacts artifacts: 'playwright-report/**', allowEmptyArchive: true

            // Publish HTML report
            publishHTML(target: [
                reportDir: 'playwright-report',
                reportFiles: 'index.html',
                reportName: 'Playwright Report',
                keepAll: true,
                alwaysLinkToLastBuild: true,
                allowMissing: false
            ])
        }

        success {
            emailext (
                subject: "✅ Jenkins Build SUCCESS - Playwright Tests Passed",
                body: """
                <h3>Build Successful ✅</h3>
                <p>All Playwright tests passed successfully.</p>
                <p><b>Job:</b> ${env.JOB_NAME}</p>
                <p><b>Build Number:</b> ${env.BUILD_NUMBER}</p>
                <p><b>Report:</b> <a href="${env.BUILD_URL}Playwright_Report/">Click Here</a></p>
                """,
                mimeType: 'text/html',
                to: "quizbuzz1992@gmail.com",
                attachmentsPattern: 'playwright-report/**'
            )
        }

        failure {
            emailext (
                subject: "❌ Jenkins Build FAILED - Playwright Tests",
                body: """
                <h3>Build Failed ❌</h3>
                <p>Some Playwright tests failed.</p>
                <p><b>Job:</b> ${env.JOB_NAME}</p>
                <p><b>Build Number:</b> ${env.BUILD_NUMBER}</p>
                <p><b>Check Console:</b> <a href="${env.BUILD_URL}console">Click Here</a></p>
                """,
                mimeType: 'text/html',
                to: "quizbuzz1992@gmail.com",
                attachmentsPattern: 'playwright-report/**'
            )
        }
    }
}