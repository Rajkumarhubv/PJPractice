pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Rajkumarhubv/PJPractice.git'
            }
        }

        stage('Install') {
            steps {
                bat 'npm install'
                bat 'npx playwright install'
            }
        }

        stage('Run Tests') {
            steps {
                // Force HTML report generation
                bat 'npx playwright test --reporter=html'
            }
        }

        stage('Verify Report') {
            steps {
                // Debug: check if report files exist
                bat 'dir playwright-report'
            }
        }
    }

    post {
        always {
            // Archive full report
            archiveArtifacts artifacts: 'playwright-report/**', allowEmptyArchive: true

            // Publish HTML report properly
            publishHTML(target: [
                reportDir: 'playwright-report',
                reportFiles: 'index.html',
                reportName: 'Playwright Report',
                keepAll: true,
                alwaysLinkToLastBuild: true,
                allowMissing: false
            ])
        }
    }
}